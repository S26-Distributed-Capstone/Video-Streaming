    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_R2" name="yes" sourceRef="Gateway_Recovered" targetRef="Task_ProcessSegments">
      <bpmn:documentation id="documentation_i0GZqQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_R3" name="no" sourceRef="Gateway_Recovered" targetRef="Task_MarkFailed">
