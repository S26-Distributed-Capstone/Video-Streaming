      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_PlaybackReady" name="Playback starts">
      <bpmn:documentation id="documentation_0L1efg"/>
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_MarkFailed" name="Mark video FAILED">
      <bpmn:documentation id="documentation_6bUGMg"/>
      <bpmn:incoming>Flow_F1</bpmn:incoming>
