      <bpmn:incoming>Flow_R3</bpmn:incoming>
      <bpmn:outgoing>Flow_F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Failed" name="Workflow failed">
      <bpmn:documentation id="documentation_F4XQUA"/>
      <bpmn:incoming>Flow_F4</bpmn:incoming>
    </bpmn:endEvent>
