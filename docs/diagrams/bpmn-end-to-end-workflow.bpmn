    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F4" sourceRef="Task_MarkFailed" targetRef="End_Failed">
      <bpmn:documentation id="documentation_VuoHnw"/>
    </bpmn:sequenceFlow>
  </bpmn:process>
