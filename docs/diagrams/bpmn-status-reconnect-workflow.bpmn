<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_StatusReconnect" targetNamespace="http://distributed26.com/bpmn">
  <bpmn:process id="Process_StatusReconnect" isExecutable="false" name="Status Snapshot, Live Updates, and Reconnect" processType="Public">
    <bpmn:documentation id="documentation_zqxC0w"/>
    <bpmn:extensionElements>
      <open-bpmn:auto-align/>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_OpenStatus" name="Client opens status channel">
      <bpmn:documentation id="documentation_b0eY6A"/>
      <bpmn:outgoing>SR_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_BindJob" name="Bind WebSocket or status request to videoId">
      <bpmn:documentation id="documentation_QOsT8w"/>
      <bpmn:incoming>SR_1</bpmn:incoming>
      <bpmn:outgoing>SR_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_SnapshotAndSubscribe" name="Load snapshot and subscribe">
      <bpmn:documentation id="documentation_O1J90A"/>
      <bpmn:incoming>SR_2</bpmn:incoming>
      <bpmn:outgoing>SR_3</bpmn:outgoing>
      <bpmn:outgoing>SR_4</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_LoadSnapshot" name="Query Postgres snapshot">
      <bpmn:documentation id="documentation_AWZpOQ"/>
      <bpmn:incoming>SR_3</bpmn:incoming>
      <bpmn:outgoing>SR_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SubscribeEvents" name="Subscribe to RabbitMQ status events">
      <bpmn:documentation id="documentation_Uzq8NQ"/>
      <bpmn:incoming>SR_4</bpmn:incoming>
      <bpmn:outgoing>SR_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Gateway_ReadyToStream" name="Snapshot and subscription ready">
      <bpmn:documentation id="documentation_KogONA"/>
      <bpmn:incoming>SR_5</bpmn:incoming>
      <bpmn:incoming>SR_6</bpmn:incoming>
      <bpmn:outgoing>SR_7</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Task_SendSnapshot" name="Send initial snapshot">
      <bpmn:documentation id="documentation_pFrjeQ"/>
      <bpmn:incoming>SR_7</bpmn:incoming>
      <bpmn:outgoing>SR_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PushLiveUpdates" name="Push live upload / transcode updates">
      <bpmn:documentation id="documentation_0bx6fw"/>
      <bpmn:incoming>SR_8</bpmn:incoming>
      <bpmn:outgoing>SR_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent attachedToRef="Task_PushLiveUpdates" id="Boundary_StatusDisconnect" name="Status service disconnect">
      <bpmn:documentation id="documentation_NbL3bA"/>
      <bpmn:errorEventDefinition/>
      <bpmn:outgoing>SR_F1</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:task id="Task_Reconnect" name="Client reconnects to healthy status instance">
      <bpmn:documentation id="documentation_p0Ntxw"/>
      <bpmn:incoming>SR_F1</bpmn:incoming>
      <bpmn:outgoing>SR_R1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_StatusClosed" name="Client closes status channel">
      <bpmn:documentation id="documentation_GSzy9w"/>
      <bpmn:incoming>SR_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SR_1" sourceRef="Start_OpenStatus" targetRef="Task_BindJob">
      <bpmn:documentation id="documentation_6vCMNA"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_2" sourceRef="Task_BindJob" targetRef="Gateway_SnapshotAndSubscribe">
      <bpmn:documentation id="documentation_wON4Ww"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_3" sourceRef="Gateway_SnapshotAndSubscribe" targetRef="Task_LoadSnapshot">
      <bpmn:documentation id="documentation_zpnPvw"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_4" sourceRef="Gateway_SnapshotAndSubscribe" targetRef="Task_SubscribeEvents">
      <bpmn:documentation id="documentation_iBNDeA"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_5" sourceRef="Task_LoadSnapshot" targetRef="Gateway_ReadyToStream">
      <bpmn:documentation id="documentation_XxVNJg"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_6" sourceRef="Task_SubscribeEvents" targetRef="Gateway_ReadyToStream">
      <bpmn:documentation id="documentation_09l0Iw"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_7" sourceRef="Gateway_ReadyToStream" targetRef="Task_SendSnapshot">
      <bpmn:documentation id="documentation_xwri9A"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_8" sourceRef="Task_SendSnapshot" targetRef="Task_PushLiveUpdates">
      <bpmn:documentation id="documentation_LHSXEw"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_9" sourceRef="Task_PushLiveUpdates" targetRef="End_StatusClosed">
      <bpmn:documentation id="documentation_SHrPfA"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_F1" sourceRef="Boundary_StatusDisconnect" targetRef="Task_Reconnect">
      <bpmn:documentation id="documentation_4nq5LQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SR_R1" sourceRef="Task_Reconnect" targetRef="Task_BindJob">
      <bpmn:documentation id="documentation_p03Gpw"/>
    </bpmn:sequenceFlow>
  </bpmn:process>
