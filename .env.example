# MinIO Object Storage
# Use service hostnames for docker-compose / swarm
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=uploads
MINIO_REGION=us-east-1

CHUNK_DURATION_SECONDS=6

# PostgreSQL
# Docker-compose variables
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=videostreaming
# Application variables (keep in sync with above)
# Use service hostname for docker-compose / swarm
PG_URL=jdbc:postgresql://postgres:5432/videostreaming
PG_USER=your_postgres_user
PG_PASSWORD=your_postgres_password
PG_DB=videostreaming

MACHINE_ID=dev-machine-1

# RabbitMQ
# Use service hostname for docker-compose / swarm
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_ERLANG_COOKIE=your_erlang_cookie_secret

RABBITMQ_EXCHANGE=upload.events

# Status queue: UI/status-service/progress fan-out
# Browser progress flows through this queue via status-service.
RABBITMQ_STATUS_QUEUE=upload.status.queue
RABBITMQ_STATUS_BINDING=upload.status.*
RABBITMQ_STATUS_QUEUE_PROCESSING=processing.events.queue
RABBITMQ_FAILURE_BINDING=upload.failure

# Task queue: distributed transcoding work items
# upload-service publishes one task per (segment, profile); processing-service consumes them.
RABBITMQ_TASK_QUEUE=upload.task.queue
RABBITMQ_TASK_BINDING=upload.task.transcode

# Status service port (used by upload service to build WS URLs)
STATUS_PORT=8081

# Processing service port and worker pool size
# Rule of thumb: WORKER_POOL_SIZE = floor(CPU_cores / THREADS_PER_WORKER)
PROCESSING_PORT=8082
STREAMING_PORT=8083
WORKER_POOL_SIZE=6
THREADS_PER_WORKER=1
FFMPEG_PRESET=superfast

# Storage retry (ResilientStorageClient) — retry + exponential backoff for MinIO outages
# Initial backoff delay in milliseconds
STORAGE_RETRY_INITIAL_DELAY_MS=500
# Maximum backoff delay ceiling in milliseconds
STORAGE_RETRY_MAX_DELAY_MS=30000
# Maximum retry attempts (0 = unlimited, keeps retrying until MinIO recovers)
STORAGE_RETRY_MAX_ATTEMPTS=0

# Note: SERVICE_MODE plus the status/task/failure queue settings are typically
# overridden per-service in docker-compose.yaml, because upload/status/
# processing do not all consume the same RabbitMQ paths. The values above
# are shared defaults for local development and documentation.

# Node watcher
WATCH_CONTAINER_NAME_PREFIX=upload-service,video_upload-service
FAILURE_REASON=container_died
UPDATE_DB_STATUS=true
PYTHONUNBUFFERED=1
DEBUG_EVENTS=true
DEDUP_WINDOW_SECONDS=3

# Chaos monkey
CHAOS_ENABLED=false

# Preset: core | infra | all | aggressive
# - core: upload-service, processing-service, streaming-service
# - infra: rabbitmq, postgres, minio
# - all: everything
# - aggressive: core + infra with hard kills
CHAOS_PRESET=core

# Override preset with explicit service list (optional)
# CHAOS_TARGET_SERVICES=upload-service,processing-service,streaming-service,rabbitmq,postgres

# Timing configuration
CHAOS_INTERVAL_MIN=30
CHAOS_INTERVAL_MAX=60

# Kill probability per interval (0.0 = never, 1.0 = always)
CHAOS_PROBABILITY=0.7

# Graceful restart for stateful services (rabbitmq, postgres, minio)
# true = 30s grace period for shutdown | false = hard kill
CHAOS_STATEFUL_SAFE_MODE=true

# Kubernetes namespace
CHAOS_NAMESPACE=default

# Log kills to RabbitMQ dev logs
CHAOS_LOG_TO_RABBITMQ=true
